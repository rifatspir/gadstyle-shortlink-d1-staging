# Keep DATABASE_URL and DIRECT_URL during production cutover for rollback safety.
# After production is verified on Worker + D1, these can be removed only if you no longer use Prisma fallback paths.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
APP_BASE_URL="https://app.gadstyle.com"
SESSION_SECRET="replace-with-a-long-random-string"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH="replace-with-bcrypt-hash"
SHORTLINK_API_BASE_URL="https://gadstyle-shortlink-worker.gadstyle.workers.dev"
